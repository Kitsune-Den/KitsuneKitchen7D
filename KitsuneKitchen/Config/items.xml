<?xml version="1.0" encoding="UTF-8"?>
<configs>

	<!-- ============================================================ -->
	<!-- SHAM SANDWICH VENDOR FIX                                      -->
	<!-- Makes Sham Sandwiches sellable to traders for ~2 dukes        -->
	<!-- ============================================================ -->
	<append xpath="/items/item[@name='foodShamSandwich']">
		<property name="EconomicValue" value="10"/>
	</append>

	<!-- ============================================================ -->
	<!-- SIMPLE DISHES — From raw ingredients, early-game friendly      -->
	<!-- ============================================================ -->

	<!-- Fox's Hash: Potato + Egg on the grill -->
	<append xpath="/items">
		<item name="foodKKFoxHash">
			<property name="Extends" value="foodBakedPotato"/>
			<property name="CustomIcon" value="foodBakedPotato"/>
			<property name="CustomIconTint" value="f0c050"/>
			<property name="DescriptionKey" value="foodKKFoxHash"/>
			<property name="EconomicValue" value="8"/>
			<property name="UnlockedBy" value="craftingFood"/>
			<property name="Group" value="Food/Cooking,CFFood/Cooking"/>
			<effect_group tiered="false" name="KK Fox Hash">
				<triggered_effect trigger="onSelfPrimaryActionEnd" action="ModifyCVar" cvar="$foodAmountAdd" operation="add" value="22"/>
				<triggered_effect trigger="onSelfPrimaryActionEnd" action="ModifyCVar" cvar="foodHealthAmount" operation="add" value="8"/>
				<triggered_effect trigger="onSelfPrimaryActionEnd" action="ModifyCVar" cvar=".foodStaminaBonusAdd" operation="add" value="10"/>
				<triggered_effect trigger="onSelfPrimaryActionEnd" action="AddBuff" buff="buffProcessConsumables"/>
			</effect_group>
		</item>
	</append>

